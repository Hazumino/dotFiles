{
    "layer": "bottom",
    "position": "bottom",
    "height": 10,
    "width": 1050,
    "margin": "9, 0, 2, 0",
    "modules-center": ["custom/backward", "custom/forward"],
    "modules-left": [ "wlr/workspaces", "cpu", "memory", "disk"],
    "modules-right": ["custom/kb","backlight", "network", "battery", "clock", "custom/power"],

    "wlr/workspaces": {
        "format": "{icon}",
        "format-icons":{ 
        "1": "ΎΕι",
        "2": "≤░Ι╣",
        "3": "ΎΥΦ",
        "4": "≤░ζγ",
        "5": "≤░βψ",
        "urgent": "ΎΒς",
        "focused": "ΎΗΤ",
        "default": "ΎΕΣ"},
        "on-click": "activate",
    },

    "custom/kb": {
        "device": "kbd_backlight",
        "format": "≤░ΝΝ   {}%",
        "interval": 1,
        "exec": "echo $((($(brightnessctl --device='kbd_backlight' get)*100) / 255))",
        "format-icons": ["≤░ΝΝ"],
        "on-scroll-down": "brightnessctl --device='kbd_backlight' set 1%-",
        "on-scroll-up": "brightnessctl --device='kbd_backlight' set 1%+"
    },

    "custom/youtube": {
        "format":" ≤░ΩΔ ",
        "on-click": "exec firefox youtube.com",
        "tooltip": false,
    },

    "custom/forward": {
        "format":" ΎΒΟ ",
        "on-click": "exec ~/dotFiles/swww.sh forward",
        "tooltip": false,
    },

    "custom/backward": {
        "format":" ΎΒΛ ",
        "on-click": "exec ~/dotFiles/swww.sh backward",
        "tooltip": false,
    },
    "custom/reddit": {
        "format":" ΎΗκ ",
        "on-click": "exec firefox reddit.com",
        "tooltip": false,
    },

    "custom/github": {
        "format":" ΌςΕ ",
        "on-click": "exec firefox github.com",
        "tooltip": false,
    },

    "wlr/window": {
        "max-length": 25,
        "tooltip": false
    },

    "clock": {
        "interval": 1,
        "locale": "C", 
        "format": "{:%I:%M %p}",
        "format-alt": "ΎΒ│  {:%a,%b %d}" // Icon: calendar-alt
    },

    "cpu": {
        "interval": 10,
        "format": "ΎΜδ   {usage}%",
        "max-length": 10,
        "on-click": "kitty -e 'htop'"
    },

    "memory": {
        "interval": 30,
        "format": "ΎΔΚ  {used:0.2f}GB",

        "max-length": 10,
        "tooltip": false,
        "warning": 70,
        "critical": 90
    },

    "battery": {
        "states": {
            // "good": 95,
            "warning": 30,
            "critical": 15
        },
        "format": "{icon}   {capacity}%",
        "format-charging": "έγκ  {capacity}%",
        "format-plugged": "ΎΘο   {capacity}%",
        // "format-good": "", // An empty format will hide the module
        // "format-full": "",
        "format-icons": ["ΎΚΕ", "ΎΚΔ", "ΎΚΓ", "ΎΚΒ", "ΎΚΑ"]
        //"format-alt": "{time}",
    },

    "temperature": {
        "critical-threshold": 80,
        "format-critical": "{temperatureC}┬░ ΎΜΘ",
        "format": "{temperatureC}┬░ ΎΜΚ"
    },

    "network": {
        "format": "{icon}",
        "format-alt": "{ipaddr}/{cidr} {icon}",
        "format-alt-click": "click-right",
        "format-wifi": "{icon}   ({signalStrength}%)",
        "format-icons": {
            "wifi": ["Ύςσ", "Ύςρ" ,"ΎΘτ"],
            "ethernet": ["Ύδ┐"],
            "disconnected": ["Ύβγ"]
        },
        "on-click": "kitty nmtui",
        "tooltip-format": "{ifname}: {ipaddr}",
    },

    "pulseaudio": {
      // "scroll-step": 1, // %, can be a float
      "format": "{icon}   {volume}% ",
      "format-bluetooth": "{icon}ΎΛΦ {volume}% {format_source}",
      "format-bluetooth-muted": "ΎΣο {format_source}",
      "format-muted": "ΎΣο  {format_source}",
      "format-icons": {
        "headphone": "ΎΑξ",
        "hands-free": "ΎΨΡ",
        "headset": "ΏθΟπ",
        "phone": "ΎΓΧ",
        "portable": "ΎΓΧ",
        "car": "ΎΗ╣",
        "default": ["ΎΑο", "ΎΑπ", "ΎΑρ"]
      },
      "on-click": "pavucontrol"
    },

    "backlight": {
        "device": "intel_backlight",
        "format": "{icon}   {percent}%",
        "format-icons": ["ΎΗΖ"],
        "on-scroll-down": "brightnessctl -c backlight set 1%-",
        "on-scroll-up": "brightnessctl -c backlight set +1%"
    },


    "idle_inhibitor": {
        "format": "{icon}",
        "format-icons":{
            "activated": "ΎΒχ",
            "deactivated": "ΎΒ░"
        }
    },

    "tray": {
        "icon-size": 15
    },

    "disk": {
        "format": "ΎΓι   {free}" 
    },

    "custom/recorder": {
        "format": "ΎΑ╜ Rec",
        "format-disabled": "ΎΑ╜ Off-air", //An empty format will hide the module.
        "return-type": "json",
        "interval": 1,
        "exec": "echo '{\"class\": \"recording\"}'",
        "exec-if": "pgrep wf-recorder",
    },

    "custom/audiorec": {
        "format": "έβυ Rec",
        "format-disabled": "έβυ Off-air", //An empty format will hide the module.
        "return-type": "json",
        "interval": 1,
        "exec": "echo '{\"class\": \"audio recording\"}'",
        "exec-if": "pgrep ffmpeg",
    },

    "mpd": {
      "format": "{stateIcon} {artist} - {title}",
      "format-disconnected": "ΏθΟ╢",
      "format-stopped": "έβς",
      "interval": 10,
      "consume-icons": {
        "on": "ΎΔΕ " // Icon shows only when "consume" is on
      },
      "random-icons": {
        "off": "<span color=\"#f53c3c\">ΎΒ┤</span> ", // Icon grayed out when "random" is off
        "on": "ΎΒ┤ "
      },
      "repeat-icons": {
        "on": "ΎΑη "
      },
      "single-icons": {
        "on": "ΎΑη1 "
      },
      "state-icons": {
        "paused": "ΎΒΝ",
        "playing": "ΎΒΜ"
      },
      "tooltip-format": "MPD (connected)",
      "tooltip-format-disconnected": "MPD (disconnected)",
      "max-length": 45
    },

    "custom/power": {
        "format":"  έΠ╗  ",
        "on-click": "exec ~/.config/rofi/powermenu/type-2/powermenu.sh",
        "tooltip": false,
    },
}
