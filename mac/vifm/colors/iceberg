" iceberg
" by Puvendran Pillay
"
" This colorscheme is based on iceberg colorscheme for vim
" by cocopon

highlight clear

highlight Win cterm=none ctermfg=255 ctermbg=none
highlight Directory cterm=bold ctermfg=109 ctermbg=none
highlight Link cterm=bold ctermfg=216 ctermbg=none
highlight BrokenLink cterm=bold ctermfg=red ctermbg=none
highlight Socket cterm=bold ctermfg=magenta ctermbg=none
highlight Device cterm=bold ctermfg=red ctermbg=default
highlight Fifo cterm=bold ctermfg=cyan ctermbg=default
highlight Executable cterm=none ctermfg=150 ctermbg=none
highlight Selected cterm=none ctermfg=255 ctermbg=none
highlight CurrLine cterm=reverse
highlight TopLine cterm=none ctermfg=255 ctermbg=none
highlight TopLineSel cterm=bold ctermfg=110 ctermbg=none
highlight StatusLine cterm=none ctermfg=240 ctermbg=none
highlight WildMenu cterm=underline,reverse ctermfg=255 ctermbg=black
highlight CmdLine cterm=none ctermfg=255 ctermbg=none
highlight ErrorMsg cterm=none ctermfg=203 ctermbg=none
highlight Border cterm=none ctermfg=black ctermbg=none
highlight JobLine cterm=bold,reverse ctermfg=black ctermbg=none
highlight SuggestBox cterm=bold ctermfg=default ctermbg=none
highlight CmpMismatch cterm=bold ctermfg=255 ctermbg=none
highlight AuxWin cterm=bold,underline,reverse,standout ctermfg=default ctermbg=none
